# Telegram Bot Configuration
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# CDC Booking Configuration
COURSE_CODE=EV-ELITETEAM
CHECK_INTERVAL_MINUTES=5

# Full Cookie header string from booking request
COOKIES="ILOAFLLQ=...; ASP.NET_SessionId=...; cf_clearance=..."

# Full URL-encoded POST payload from booking POST request
POST_PAYLOAD="ctl00$ContentPlaceHolder1$ScriptManager1=...&__VIEWSTATE=...&__EVENTVALIDATION=..."

